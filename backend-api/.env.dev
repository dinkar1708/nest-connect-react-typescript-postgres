# Development - Flexible DB: replace DATABASE_URL for any PostgreSQL instance
# Default: local Postgres (Docker or native). Swap for Supabase/Railway/Neon/etc. as needed.

DATABASE_URL=postgresql://postgres:password@localhost:5432/nestconnect_dev

JWT_SECRET=dev_secret_key_change_in_production
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

PORT=4000

NODE_ENV=development
